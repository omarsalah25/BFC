@model CarRentalPortfolio.Models.HeroImage
@{
    ViewData["Title"] = "Add Hero Image";
    var isArabic = Context.Request.Cookies["Language"] == "ar";
}

<div class="admin-form-page">
    <div class="container">
        <div class="form-container">
            <div class="form-header">
                <i class="fas fa-plus-circle"></i>
                <h1>@(isArabic ? "إضافة صورة رئيسية جديدة" : "Add New Hero Image")</h1>
            </div>

            <form asp-action="AddHeroImage" method="post" enctype="multipart/form-data" class="admin-form">
                <div class="form-grid">
                    <div class="form-group full-width">
                        <label asp-for="Title">@(isArabic ? "العنوان (إنجليزي)" : "Title (English)")</label>
                        <input asp-for="Title" class="form-control" required />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="form-group full-width">
                        <label asp-for="TitleAr">@(isArabic ? "العنوان (عربي)" : "Title (Arabic)")</label>
                        <input asp-for="TitleAr" class="form-control" required />
                        <span asp-validation-for="TitleAr" class="text-danger"></span>
                    </div>

                    <div class="form-group full-width">
                        <label asp-for="Subtitle">@(isArabic ? "العنوان الفرعي (إنجليزي)" : "Subtitle (English)")</label>
                        <input asp-for="Subtitle" class="form-control" required />
                        <span asp-validation-for="Subtitle" class="text-danger"></span>
                    </div>

                    <div class="form-group full-width">
                        <label asp-for="SubtitleAr">@(isArabic ? "العنوان الفرعي (عربي)" : "Subtitle (Arabic)")</label>
                        <input asp-for="SubtitleAr" class="form-control" required />
                        <span asp-validation-for="SubtitleAr" class="text-danger"></span>
                    </div>

                    <div class="form-group full-width">
                        <label asp-for="ImageUrl">@(isArabic ? "رابط الصورة (اختياري)" : "Image URL (Optional)")</label>
                        <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/image.jpg" />
                        <small class="form-text text-muted">@(isArabic ? "اترك هذا الحقل فارغاً إذا كنت ستقوم برفع صورة" : "Leave this empty if you're uploading an image")</small>
                    </div>

                    <div class="form-group full-width">
                        <label>@(isArabic ? "رفع صورة" : "Upload Image")</label>
                        <div class="file-upload-wrapper">
                            <input type="file" name="imageFile" class="file-upload-input" id="imageFile" accept="image/*" />
                            <label for="imageFile" class="file-upload-label">
                                <i class="fas fa-cloud-upload-alt"></i>
                                @(isArabic ? "اختر صورة" : "Choose Image")
                            </label>
                            <span class="file-name" id="file-name">@(isArabic ? "لم يتم اختيار ملف" : "No file chosen")</span>
                        </div>
                        <small class="form-text text-muted">@(isArabic ? "الصيغ المدعومة: JPG, PNG, GIF (الحد الأقصى 5 ميجابايت)" : "Supported formats: JPG, PNG, GIF (Max 5MB)")</small>
                    </div>

                    <div class="form-group full-width checkbox-group">
                        <label class="checkbox-label">
                            <input asp-for="IsActive" type="checkbox" />
                            <span class="checkbox-custom"></span>
                            @(isArabic ? "تعيين كصورة نشطة" : "Set as active image")
                        </label>
                        <small class="form-text text-muted">@(isArabic ? "إذا كان نشطاً، ستظهر هذه الصورة في الصفحة الرئيسية" : "If active, this image will appear on the homepage")</small>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-save">
                        <i class="fas fa-save"></i>
                        @(isArabic ? "حفظ" : "Save")
                    </button>
                    <a href="/Admin/HeroImages" class="btn-cancel">
                        <i class="fas fa-times"></i>
                        @(isArabic ? "إلغاء" : "Cancel")
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('imageFile').addEventListener('change', function(e) {
            const fileName = e.target.files[0] ? e.target.files[0].name : '@(isArabic ? "لم يتم اختيار ملف" : "No file chosen")';
            document.getElementById('file-name').textContent = fileName;
        });
    </script>
}