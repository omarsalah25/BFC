@model IEnumerable<CarRentalPortfolio.Models.Car>
@{
    ViewData["Title"] = "Manage Cars";
    var isArabic = Context.Request.Cookies["Language"] == "ar";
}

<div class="admin-cars">
    <div class="container">
        <div class="header-actions">
            <h1>@(isArabic ? "إدارة السيارات" : "Manage Cars")</h1>
            <a href="/Admin/AddCar" class="btn-add">
                <i class="fas fa-plus"></i>
                @(isArabic ? "إضافة سيارة" : "Add New Car")
            </a>
        </div>

        <div class="cars-table-container">
            <table class="cars-table">
                <thead>
                    <tr>
                        <th>@(isArabic ? "الصورة" : "Image")</th>
                        <th>@(isArabic ? "الاسم" : "Name")</th>
                        <th>@(isArabic ? "السعر/اليوم" : "Price/Day")</th>
                        <th>@(isArabic ? "الحالة" : "Status")</th>
                        <th>@(isArabic ? "السنة" : "Year")</th>
                        <th>@(isArabic ? "الإجراءات" : "Actions")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var car in Model)
                    {
                        <tr id="car-row-@car.Id">
                            <td>
                                @if (!string.IsNullOrEmpty(car.ImageUrl))
                                {
                                    <img src="@car.ImageUrl" alt="@car.Name" class="table-car-image">
                                }
                                else
                                {
                                    <div class="table-image-placeholder">
                                        <i class="fas fa-car"></i>
                                    </div>
                                }
                            </td>
                            <td>@(isArabic? car.NameAr: car.Name)</td>
                            <td>@car.PricePerDay.ToString("N0") EGP</td>
                            <td>
                                <span class="status-badge @(car.IsAvailable ? "available" : "unavailable")">
                                    @(car.IsAvailable ? (isArabic ? "متاحة" : "Available") : (isArabic ? "غير متاحة" : "Unavailable"))
                                </span>
                            </td>
                            <td>@car.Year</td>
                            <td class="actions">
                                <a href="/Admin/EditCar/@car.Id" class="btn-edit">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <button onclick="deleteCar(@car.Id)" class="btn-delete">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function deleteCar(id) {
            if (confirm('@(isArabic ? "هل أنت متأكد من حذف هذه السيارة؟" : "Are you sure you want to delete this car?")')) {
                $.post('/Admin/DeleteCar', { id: id })
                    .done(function(response) {
                        if (response.success) {
                            $('#car-row-' + id).fadeOut();
                        } else {
                            alert(response.message);
                        }
                    });
            }
        }
    </script>
}