@model CarRentalPortfolio.Models.AdminLoginViewModel
@{
    ViewData["Title"] = "Admin Login";
    var isArabic = Context.Request.Cookies["Language"] == "ar";
}

<div class="login-page">
    <div class="login-container">
        <div class="login-card">
            <div class="login-header">
                <i class="fas fa-user-shield"></i>
                <h2>@(isArabic ? "تسجيل دخول المدير" : "Admin Login")</h2>
            </div>

            <form asp-action="Login" method="post" class="login-form">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group">
                    <label asp-for="Username">@(isArabic ? "اسم المستخدم" : "Username")</label>
                    <input asp-for="Username" class="form-control" />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password">@(isArabic ? "كلمة المرور" : "Password")</label>
                    <input asp-for="Password" class="form-control" type="password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <button type="submit" class="btn-login">
                    <i class="fas fa-sign-in-alt"></i>
                    @(isArabic ? "دخول" : "Login")
                </button>
            </form>
        </div>
    </div>
</div>