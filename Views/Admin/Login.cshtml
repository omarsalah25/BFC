@model CarRentalPortfolio.Models.AdminLoginViewModel
@{
    ViewData["Title"] = "Admin Login";
    var isArabic = Context.Request.Cookies["Language"] == "ar";
}

<div class="login-page">
    <div class="login-container">
        <div class="login-card">
            <div class="login-header">
                <i class="fas fa-user-shield"></i>
                <h2>@(isArabic ? "تسجيل دخول المدير" : "Admin Login")</h2>
                <p>@(isArabic ? "الرجاء إدخال بيانات الاعتماد الخاصة بك" : "Please enter your credentials")</p>
            </div>

            <form asp-action="Login" method="post" class="login-form">
                <div asp-validation-summary="ModelOnly" class="text-danger error-summary"></div>

                <div class="form-group">
                    <label asp-for="Username">@(isArabic ? "اسم المستخدم" : "Username")</label>
                    <div class="input-icon-wrapper">
                        <i class="fas fa-user"></i>
                        <input asp-for="Username" class="form-control" placeholder="@(isArabic ? "أدخل اسم المستخدم" : "Enter username")" />
                    </div>
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password">@(isArabic ? "كلمة المرور" : "Password")</label>
                    <div class="input-icon-wrapper">
                        <i class="fas fa-lock"></i>
                        <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <button type="submit" class="btn-login">
                    <i class="fas fa-sign-in-alt"></i>
                    @(isArabic ? "تسجيل الدخول" : "Login")
                </button>
            </form>
        </div>
    </div>
</div>