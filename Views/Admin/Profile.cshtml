@model CarRentalPortfolio.Models.AdminProfileViewModel
@{
    ViewData["Title"] = "Admin Profile";
    var isArabic = Context.Request.Cookies["Language"] == "ar";
}

<div class="admin-form-page">
    <div class="container">
        <div class="form-container" style="max-width: 600px; margin: 0 auto;">
            <div class="form-header">
                <i class="fas fa-user-edit"></i>
                <h1>@(isArabic ? "تعديل بيانات الدخول" : "Edit Admin Credentials")</h1>
            </div>

            <form asp-action="Profile" method="post" class="admin-form">
                <div class="form-group full-width">
                    <label asp-for="Username">@(isArabic ? "اسم المستخدم" : "Username")</label>
                    <input asp-for="Username" class="form-control" required />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <div class="form-group full-width">
                    <label asp-for="NewPassword">@(isArabic ? "كلمة المرور الجديدة (اتركها فارغة للاحتفاظ بالقديمة)" : "New Password (leave blank to keep current)")</label>
                    <input asp-for="NewPassword" class="form-control" type="password" />
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-save">
                        <i class="fas fa-save"></i>
                        @(isArabic ? "حفظ التغييرات" : "Save Changes")
                    </button>
                    <a href="/Admin/Dashboard" class="btn-cancel">
                        @(isArabic ? "إلغاء" : "Cancel")
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>