@{
    ViewData["Title"] = "About H-CAR";
    var isArabic = Context.Request.Cookies["Language"] == "ar";
}

<div class="about-page">
    <div class="container">
        <div class="about-header">
            <h1 class="about-title">@(isArabic ? "عن إتش-كار" : "About H-CAR")</h1>
            <div class="title-underline"></div>
        </div>

        <div class="about-content">
            <!-- Vision / Philosophy -->
            <div class="about-card philosophy-card">
                <div class="card-icon">
                    <i class="fas fa-seedling"></i>
                </div>
                <h2>@(isArabic ? "من نحن؟" : "Who We Are")</h2>
                <p class="philosophy-main">
                    @(isArabic ? "نحن شركة مصرية ناشئة نهدف إلى جعل عملية تأجير السيارات بسيطة، عملية، وبأسعار في متناول الجميع. لا نبيع لك وعوداً خيالية، بل نقدم لك سيارات نظيفة وموثوقة لتلبية احتياجاتك اليومية بأمان وشفافية تامة."
                                        : "We are an Egyptian startup aiming to make car rentals simple, practical, and affordable for everyone. We don't sell unrealistic promises; we simply provide clean, reliable cars for your everyday needs with complete transparency.")
                </p>
                <div class="philosophy-quote">
                    <i class="fas fa-quote-right"></i>
                    <p>@(isArabic ? "تنقل عملي، وموثوقية في كل مشوار." : "Practical mobility, reliability in every ride.")</p>
                </div>
            </div>

            <!-- Features Grid -->
            <div class="about-grid">
                <div class="about-card">
                    <div class="card-icon"><i class="fas fa-wallet"></i></div>
                    <h3>@(isArabic ? "أسعار اقتصادية" : "Economic Prices")</h3>
                    <p>
                        @(isArabic ? "نقدم تسعيراً عادلاً وواضحاً يناسب ميزانيتك، سواء كنت تحتاج السيارة ليوم واحد أو لعدة أسابيع."
                                                : "We offer fair and clear pricing that fits your budget, whether you need the car for a day or several weeks.")
                    </p>
                </div>

                <div class="about-card">
                    <div class="card-icon"><i class="fas fa-car-side"></i></div>
                    <h3>@(isArabic ? "سيارات عملية" : "Practical Cars")</h3>
                    <p>
                        @(isArabic ? "أسطولنا يركز على السيارات الاقتصادية والعملية التي يتم صيانتها بانتظام لضمان سلامتك على الطريق."
                                                : "Our fleet focuses on practical, economic cars that are regularly maintained to ensure your safety on the road.")
                    </p>
                </div>

                <div class="about-card">
                    <div class="card-icon"><i class="fas fa-user-friends"></i></div>
                    <h3>@(isArabic ? "خدمة ودودة وشخصية" : "Friendly Service")</h3>
                    <p>
                        @(isArabic ? "كشركة ناشئة، نحن نهتم حقاً بكل عميل. نتعامل معك بمرونة وود لضمان تجربة إيجابية وخالية من التوتر."
                                                : "As a startup, we truly care about every customer. We deal with you flexibly and amicably to ensure a stress-free experience.")
                    </p>
                </div>

                <div class="about-card">
                    <div class="card-icon"><i class="fas fa-file-signature"></i></div>
                    <h3>@(isArabic ? "إجراءات بسيطة" : "Simple Process")</h3>
                    <p>
                        @(isArabic ? "ابتعدنا عن التعقيدات الورقية الطويلة. إجراءاتنا مباشرة وواضحة لتستلم سيارتك في أسرع وقت ممكن."
                                                : "We moved away from lengthy paperwork. Our procedures are straightforward so you can get your car as quickly as possible.")
                    </p>
                </div>
            </div>

            <!-- Why Choose Us Section -->
            <div class="why-choose-section">
                <h2 class="section-title">@(isArabic ? "لماذا تختار التعامل معنا؟" : "Why Choose Us?")</h2>
                <div class="why-choose-grid">
                    <div class="why-choose-item">
                        <div class="why-icon"><i class="fas fa-check-circle"></i></div>
                        <div class="why-content">
                            <h3>@(isArabic ? "شفافية تامة" : "Total Transparency")</h3>
                            <p>@(isArabic ? "لا توجد رسوم خفية. ما تراه هو ما تدفعه، ويتم توضيح كافة شروط الإيجار قبل الاستلام." : "No hidden fees. What you see is what you pay, and all terms are clarified before pickup.")</p>
                        </div>
                    </div>

                    <div class="why-choose-item">
                        <div class="why-icon"><i class="fas fa-check-circle"></i></div>
                        <div class="why-content">
                            <h3>@(isArabic ? "صيانة دورية" : "Regular Maintenance")</h3>
                            <p>@(isArabic ? "نهتم ميكانيكياً بكل سيارة، ونتأكد من نظافتها قبل تسليمها لك لضمان رحلة آمنة." : "We care mechanically for every car and ensure its cleanliness before handing it over for a safe trip.")</p>
                        </div>
                    </div>

                    <div class="why-choose-item">
                        <div class="why-icon"><i class="fas fa-check-circle"></i></div>
                        <div class="why-content">
                            <h3>@(isArabic ? "تواصل سهل وسريع" : "Easy Communication")</h3>
                            <p>@(isArabic ? "نحن متاحون للرد على استفساراتك وترتيب حجوزاتك بكل سهولة عبر رسائل الواتساب." : "We are available to answer your inquiries and arrange bookings easily via WhatsApp messages.")</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Our Process -->
            <div class="process-section">
                <h2 class="section-title">@(isArabic ? "كيف تستأجر سيارتك؟" : "How to Rent?")</h2>
                <div class="process-grid">
                    <div class="process-step">
                        <div class="step-number">1</div>
                        <div class="step-icon"><i class="fas fa-mobile-alt"></i></div>
                        <h3>@(isArabic ? "تواصل معنا" : "Contact Us")</h3>
                        <p>@(isArabic ? "راسلنا على واتساب للاستفسار عن السيارات المتاحة في التواريخ المطلوبة." : "Message us on WhatsApp to inquire about available cars for your dates.")</p>
                    </div>

                    <div class="process-step">
                        <div class="step-number">2</div>
                        <div class="step-icon"><i class="fas fa-id-card"></i></div>
                        <h3>@(isArabic ? "تجهيز الأوراق" : "Prepare Docs")</h3>
                        <p>@(isArabic ? "أرسل لنا صورة البطاقة ورخصة القيادة لتجهيز العقد مسبقاً." : "Send us a copy of your ID and driver's license to prepare the contract.")</p>
                    </div>

                    <div class="process-step">
                        <div class="step-number">3</div>
                        <div class="step-icon"><i class="fas fa-map-marker-alt"></i></div>
                        <h3>@(isArabic ? "استلام السيارة" : "Pick Up")</h3>
                        <p>@(isArabic ? "نلتقي في أحد فروعنا أو نقطة تسليم متفق عليها لفحص السيارة وتوقيع العقد." : "Meet at our branch or an agreed point to inspect the car and sign the contract.")</p>
                    </div>

                    <div class="process-step">
                        <div class="step-number">4</div>
                        <div class="step-icon"><i class="fas fa-key"></i></div>
                        <h3>@(isArabic ? "استلم المفتاح" : "Get the Keys")</h3>
                        <p>@(isArabic ? "انطلق في مشوارك بأمان، نحن هنا لدعمك إذا احتجت لأي شيء." : "Start your journey safely, we are here to support you if you need anything.")</p>
                    </div>
                </div>
            </div>

            <!-- Realistic FAQ Section -->
            <div class="faq-section">
                <h2 class="section-title">@(isArabic ? "أسئلة شائعة" : "Common Questions")</h2>
                <div class="faq-grid">
                    <div class="faq-item">
                        <div class="faq-question" onclick="toggleFAQ(this)">
                            <h3>@(isArabic ? "ما هي المستندات المطلوبة للتأجير؟" : "What documents are required?")</h3>
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">
                            <p>@(isArabic ? "تحتاج إلى بطاقة رقم قومي سارية، ورخصة قيادة سارية، وإيصال إثبات سكن (في بعض الحالات)." : "You need a valid National ID, a valid driver's license, and proof of residence (in some cases).")</p>
                        </div>
                    </div>

                    <div class="faq-item">
                        <div class="faq-question" onclick="toggleFAQ(this)">
                            <h3>@(isArabic ? "هل يوجد حد أقصى للكيلومترات؟" : "Is there a daily mileage limit?")</h3>
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">
                            <p>@(isArabic ? "نعم، للحفاظ على جودة سياراتنا يوجد حد يومي للكيلومترات يتم الاتفاق عليه وتوضيحه في العقد، ويتم احتساب رسوم بسيطة للكيلومترات الزائدة." : "Yes, to maintain our cars' condition, there is a daily limit agreed upon in the contract. A small fee applies for extra kilometers.")</p>
                        </div>
                    </div>

                    <div class="faq-item">
                        <div class="faq-question" onclick="toggleFAQ(this)">
                            <h3>@(isArabic ? "أين يتم استلام وتسليم السيارة؟" : "Where do I pick up/drop off the car?")</h3>
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">
                            <p>@(isArabic ? "يتم التسليم في فروعنا الأساسية، ويمكننا الترتيب لتسليم السيارة في أماكن معينة داخل المدينة بالاتفاق المسبق (قد تطبق رسوم توصيل)." : "Pickup is at our main branches. We can arrange delivery to specific spots in the city by prior agreement (delivery fees may apply).")</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Call to Action -->
            <div class="cta-section">
                <div class="cta-content">
                    <h2>@(isArabic ? "تبحث عن سيارة عملية لمشوارك القادم؟" : "Looking for a practical car for your next trip?")</h2>
                    <p>@(isArabic ? "تواصل معنا الآن عبر واتساب وسنسعد بمساعدتك." : "Contact us now via WhatsApp and we will be happy to assist you.")</p>
                    <a href="https://wa.me/201065646972" class="cta-button" target="_blank">
                        <i class="fab fa-whatsapp"></i>
                        @(isArabic ? "راسلنا على واتساب" : "Message us on WhatsApp")
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

