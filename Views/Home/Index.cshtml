@model IEnumerable<CarRentalPortfolio.Models.Car>
@{
    ViewData["Title"] = "H-Car - Economic Car Rentals in Egypt";
    var isArabic = Context.Request.Cookies["Language"] == "ar";
    var heroImage = ViewBag.HeroImage as CarRentalPortfolio.Models.HeroImage;
    var settings = ViewBag.Settings as CarRentalPortfolio.Models.SiteSettings ?? new CarRentalPortfolio.Models.SiteSettings();
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    /* Status styling for cars */
    .car-card.unavailable {
        opacity: 0.85;
        filter: grayscale(30%);
    }

    .btn-rent.disabled {
        background-color: #cbd5e1 !important;
        color: #64748b !important;
        cursor: not-allowed;
        pointer-events: none;
        box-shadow: none !important;
    }

    .badge-unavailable {
        background-color: #dc2626 !important;
        color: white !important;
    }

    /* Elegant Green Section Divider */
    .section-divider {
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 4rem 0;
    }

    .section-divider-line {
        height: 4px;
        width: 150px;
        background: linear-gradient(90deg, transparent, var(--primary), transparent);
        border-radius: 10px;
    }

    .section-divider-icon {
        color: var(--primary);
        font-size: 1.5rem;
        margin: 0 15px;
        opacity: 0.8;
    }

    /* Make philosophy text beautifully justified and easy to read */
    .philosophy-main {
        font-size: 1.2rem;
        line-height: 1.9;
        font-weight: 500;
        text-align: justify;
    }
</style>

<!-- 1. HERO SECTION -->
@if (heroImage != null && heroImage.IsActive)
{
    <section class="hero-section" style="background-image: linear-gradient(rgba(0,0,0,0.65), rgba(0,0,0,0.65)), url('@heroImage.ImageUrl');">
        <div class="hero-content">
            <span class="hero-welcome">@(isArabic ? "مرحباً بك في " + settings.SiteNameAr : "Welcome to " + settings.SiteName)</span>
            <h1 class="hero-title">@(isArabic? heroImage.TitleAr: heroImage.Title)</h1>
            <p class="hero-subtitle">@(isArabic? heroImage.SubtitleAr: heroImage.Subtitle)</p>
            <div class="hero-buttons">
                <a href="#cars" class="btn-primary">
                    <i class="fas fa-car"></i> @(isArabic ? "شاهد سياراتنا" : "View Our Cars")
                </a>
                <a href="#contact" class="btn-secondary">
                    <i class="fas fa-phone"></i> @(isArabic ? "تواصل معنا" : "Contact Us")
                </a>
            </div>
        </div>
    </section>
}

<!-- 2. WHY H-CAR? (PHILOSOPHY SECTION) -->
<section class="philosophy-section">
    <div class="container philosophy-grid">
        <div class="philosophy-content">
            <h2 class="section-title-left">@(isArabic ? "لماذا " + settings.SiteNameAr + "؟" : "Why " + settings.SiteName + "?")</h2>

            <div class="philosophy-message-box">
                <i class="fas fa-quote-right quote-icon"></i>
                <p class="philosophy-main">
                    @(isArabic? settings.PhilosophyAr: settings.PhilosophyEn)
                </p>
            </div>

            <div class="philosophy-stats">
                <div class="stat-item">
                    <span class="stat-number"><i class="fas fa-tags" style="color: var(--accent);"></i></span>
                    <span class="stat-label">@(isArabic ? "أسعار معقولة" : "Reasonable Prices")</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number"><i class="fas fa-shield-check" style="color: var(--accent);"></i></span>
                    <span class="stat-label">@(isArabic ? "موثوقية وأمان" : "Safe & Reliable")</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number"><i class="fas fa-smile" style="color: var(--accent);"></i></span>
                    <span class="stat-label">@(isArabic ? "عناية بالعميل" : "Customer Care")</span>
                </div>
            </div>
        </div>

        <div class="philosophy-image">
            @if (!string.IsNullOrEmpty(settings.PhilosophyImageUrl))
            {
                <img src="@settings.PhilosophyImageUrl" alt="Philosophy" class="philosophy-img">
            }
            else
            {
                <div style="width: 100%; height: 400px; background: var(--gray-200); border-radius: 20px; display: flex; align-items: center; justify-content: center;">
                    <i class="fas fa-car" style="font-size: 5rem; color: var(--gray-400);"></i>
                </div>
            }
            <div class="experience-badge">
                <i class="fas fa-star"></i>
                <span>@(isArabic ? "علامة تجارية  نفخر بها" : "Proudly  Brands")</span>
            </div>
        </div>
    </div>
</section>

<!-- 3. CARS SECTION (THE FLEET) -->
<section id="cars" class="cars-section">
    <div class="container">
        <h2 class="section-title">@(isArabic? settings.CarsTitleAr: settings.CarsTitleEn)</h2>
        <p class="section-subtitle">@(isArabic? settings.CarsSubtitleAr: settings.CarsSubtitleEn)</p>

        <div class="cars-grid">
            @foreach (var car in Model)
            {
                <div class="car-card @(car.IsAvailable ? "" : "unavailable")">
                    <div class="car-image">
                        @if (!string.IsNullOrEmpty(car.ImageUrl))
                        {
                            <img src="@car.ImageUrl" alt="@car.Name">
                        }
                        else
                        {
                            <div class="image-placeholder"><i class="fas fa-car"></i></div>
                        }

                        <div class="car-badges">
                            @if (car.IsAvailable)
                            {
                                <span class="badge available">@(isArabic ? "متاحة" : "Available")</span>
                            }
                            else
                            {
                                <span class="badge badge-unavailable">@(isArabic ? "غير متاحة" : "Unavailable")</span>
                            }
                        </div>
                    </div>

                    <div class="car-details">
                        <h3 class="car-name">@(isArabic? car.NameAr: car.Name)</h3>

                        <div class="car-specs">
                            <div class="spec-item"><i class="fas fa-gas-pump"></i> @(isArabic? car.FuelTypeAr: car.FuelType)</div>
                            <div class="spec-item"><i class="fas fa-cog"></i> @(isArabic? car.TransmissionAr: car.Transmission)</div>
                            <div class="spec-item"><i class="fas fa-users"></i> @car.Seats</div>
                        </div>

                        <p class="car-description">
                            @(isArabic? car.DescriptionAr: car.Description)
                        </p>

                        <div class="car-footer">
                            <div class="car-price">
                                <span class="price">@car.PricePerDay</span>
                                <span class="currency">@(isArabic ? "جنيه / يوم" : "EGP / Day")</span>
                            </div>

                            @if (car.IsAvailable)
                            {
                                var defaultMsg = isArabic ? settings.WhatsAppMessageAr : settings.WhatsAppMessageEn;
                                var msg = $"{defaultMsg} - {car.Name}";
                                <a href="https://wa.me/@settings.WhatsAppNumber?text=@Uri.EscapeDataString(msg)" target="_blank" class="btn-rent">
                                    <i class="fab fa-whatsapp"></i> @(isArabic ? "احجز الآن" : "Book Now")
                                </a>
                            }
                            else
                            {
                                <a href="javascript:void(0)" class="btn-rent disabled">
                                    <i class="fas fa-lock"></i> @(isArabic ? "محجوزة" : "Rented")
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- GREEN SEPARATOR LINE -->
<div class="container">
    <div class="section-divider">
        <div class="section-divider-line"></div>
        <i class="fas fa-leaf section-divider-icon"></i>
        <div class="section-divider-line"></div>
    </div>
</div>

<!-- 4. OUR ADVANTAGES (FEATURES SECTION) -->
<section class="features-section" style="padding-top: 0;">
    <div class="container">
        <h2 class="section-title">@(isArabic? settings.FeaturesTitleAr: settings.FeaturesTitleEn)</h2>
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon"><i class="fas fa-hand-holding-usd"></i></div>
                <h3>@(isArabic ? "قيمة حقيقية مقابل المال" : "Value for Money")</h3>
                <p>@(isArabic ? "نحن نؤمن بأن الإيجار يجب أن يكون بسيطاً وبدون رسوم خفية. نوفر لك سيارات اقتصادية بأسعار معقولة جداً تناسب ميزانيتك اليومية أو الأسبوعية." : "We believe renting should be simple with no hidden fees. We provide economic cars at very reasonable rates to fit your budget.")</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon"><i class="fas fa-wrench"></i></div>
                <h3>@(isArabic ? "صيانة دورية ونظافة" : "Maintained & Clean")</h3>
                <p>@(isArabic ? "رغم أن أسعارنا اقتصادية، إلا أننا لا نتنازل أبداً عن الصيانة. يتم فحص وتنظيف جميع سياراتنا بانتظام لضمان راحة بالك على الطريق." : "Although our prices are economic, we never compromise on maintenance. All cars are inspected and cleaned regularly.")</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon"><i class="fas fa-users"></i></div>
                <h3>@(isArabic ? "خدمة عملاء مهتمة" : "Dedicated Care")</h3>
                <p>@(isArabic ? "فريق عمل مصري ودود متواجد لمساعدتك خلال فترة الإيجار بمرونة وحلول عملية، لأن راحتك هي هدفنا." : "A friendly local team ready to assist you during your rental period with practical solutions and flexibility.")</p>
            </div>
        </div>
    </div>
</section>

<!-- 5. CONTACT SECTION -->
<section id="contact" class="contact-section">
    <div class="container">
        <h2 class="section-title" style="margin-bottom: 3rem;">@(isArabic? settings.ContactTitleAr: settings.ContactTitleEn)</h2>

        <div class="contact-grid">
            <div class="contact-info">
                <h3 style="color: var(--primary); font-size: 1.4rem; margin-bottom: 1.5rem; line-height: 1.6;">
                    @(isArabic? settings.ContactSubtitleAr: settings.ContactSubtitleEn)
                </h3>

                <div class="contact-details">
                    @if (!string.IsNullOrEmpty(settings.ContactEmail))
                    {
                        <div class="contact-item">
                            <i class="fas fa-envelope"></i>
                            <div>
                                <h4>@(isArabic ? "البريد الإلكتروني" : "Email")</h4>
                                <p>@settings.ContactEmail</p>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(settings.ContactPhone1) || !string.IsNullOrEmpty(settings.ContactPhone2))
                    {
                        <div class="contact-item">
                            <i class="fas fa-phone"></i>
                            <div>
                                <h4>@(isArabic ? "أرقام التواصل" : "Contact Numbers")</h4>
                                @if (!string.IsNullOrEmpty(settings.ContactPhone1))
                                {
                                    <p style="margin-bottom: 2px;">@settings.ContactPhone1</p>
                                }
                                @if (!string.IsNullOrEmpty(settings.ContactPhone2))
                                {
                                    <p>@settings.ContactPhone2</p>
                                }
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(settings.Address1En) || !string.IsNullOrEmpty(settings.Address2En))
                    {
                        <div class="contact-item">
                            <i class="fas fa-map-marker-alt"></i>
                            <div>
                                <h4>@(isArabic ? "فروعنا" : "Our Branches")</h4>
                                @if (!string.IsNullOrEmpty(settings.Address1En))
                                {
                                    <p style="margin-bottom: 2px;"><strong>1:</strong> @(isArabic? settings.Address1Ar: settings.Address1En)</p>
                                }
                                @if (!string.IsNullOrEmpty(settings.Address2En))
                                {
                                    <p><strong>2:</strong> @(isArabic? settings.Address2Ar: settings.Address2En)</p>
                                }
                            </div>
                        </div>
                    }
                </div>

                <div class="social-links">
                    @if (!string.IsNullOrEmpty(settings.FacebookUrl))
                    {
                        <a href="@settings.FacebookUrl" target="_blank" class="social-link"><i class="fab fa-facebook-f"></i></a>
                    }
                    @if (!string.IsNullOrEmpty(settings.InstagramUrl))
                    {
                        <a href="@settings.InstagramUrl" target="_blank" class="social-link"><i class="fab fa-instagram"></i></a>
                    }
                    @if (!string.IsNullOrEmpty(settings.TwitterUrl))
                    {
                        <a href="@settings.TwitterUrl" target="_blank" class="social-link"><i class="fab fa-twitter"></i></a>
                    }
                </div>
            </div>

            <div class="contact-form">
                <h3>@(isArabic ? "أرسل لنا رسالة" : "Send us a Message")</h3>
                <form id="contactForm">
                    <div class="form-group">
                        <input type="text" id="Name" placeholder="@(isArabic ? "الاسم" : "Name")" required>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <input type="tel" id="Phone" placeholder="@(isArabic ? "الهاتف" : "Phone")" required>
                        </div>
                        <div class="form-group">
                            <input type="email" id="Email" placeholder="@(isArabic ? "البريد الإلكتروني" : "Email")" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <textarea id="Message" rows="5" placeholder="@(isArabic ? "استفسارك..." : "Your inquiry...")" required></textarea>
                    </div>
                    <button type="submit" id="submitBtn" class="btn-submit">
                        <i class="fas fa-paper-plane"></i> @(isArabic ? "إرسال" : "Send")
                    </button>
                </form>
            </div>
        </div>
    </div>
</section>

<!-- JAVASCRIPT FOR CONTACT FORM -->
<script>
    document.getElementById('contactForm').addEventListener('submit', async function(e) {
        e.preventDefault();

        const btn = document.getElementById('submitBtn');
        const originalHtml = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> @(isArabic ? "جاري الإرسال..." : "Sending...")';
        btn.disabled = true;

        const formData = new URLSearchParams();
        formData.append('Name', document.getElementById('Name').value);
        formData.append('Phone', document.getElementById('Phone').value);
        formData.append('Email', document.getElementById('Email').value);
        formData.append('Message', document.getElementById('Message').value);

        try {
            const response = await fetch('/Home/SubmitContactMessage', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: formData
            });

            const result = await response.json();

            if (result.success) {
                Swal.fire({
                    icon: 'success',
                    title: '@(isArabic ? "تم الإرسال بنجاح!" : "Sent Successfully!")',
                    text: '@(isArabic ? "سنتواصل معك في أقرب وقت." : "We will contact you shortly.")',
                    confirmButtonColor: 'var(--primary)'
                });
                document.getElementById('contactForm').reset();
            } else {
                throw new Error("Failed to save.");
            }
        } catch (error) {
            Swal.fire({
                icon: 'error',
                title: 'Oops...',
                text: '@(isArabic ? "حدث خطأ أثناء الإرسال. تأكد من ملء جميع الحقول." : "An error occurred. Make sure all fields are filled.")',
                confirmButtonColor: '#ef4444'
            });
        } finally {
            btn.innerHTML = originalHtml;
            btn.disabled = false;
        }
    });
</script>