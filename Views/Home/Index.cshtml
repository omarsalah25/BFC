<!-- Statistics Banner -->
<section class="stats-banner">
    <div class="container">
        <div class="stats-grid">
            <div class="stat-item">
                <i class="fas fa-car-side"></i>
                <span class="stat-number" data-target="@Model.Count()">0</span>
                <span class="stat-label">@(isArabic ? "سيارة فاخرة" : "Luxury Cars")</span>
            </div>
            <div class="stat-item">
                <i class="fas fa-users"></i>
                <span class="stat-number" data-target="5000">0</span>
                <span class="stat-label">@(isArabic ? "عميل سعيد" : "Happy Clients")</span>
            </div>
            <div class="stat-item">
                <i class="fas fa-calendar-check"></i>
                <span class="stat-number" data-target="15000">0</span>
                <span class="stat-label">@(isArabic ? "رحلة ناجحة" : "Successful Trips")</span>
            </div>
            <div class="stat-item">
                <i class="fas fa-award"></i>
                <span class="stat-number" data-target="25">0</span>
                <span class="stat-label">@(isArabic ? "جائزة تميز" : "Awards Won")</span>
            </div>
        </div>
    </div>
</section>

<!-- Cars Section -->
<section id="cars" class="cars-section">
    <div class="container">
        <h2 class="section-title">@(isArabic ? "سياراتنا الفاخرة" : "Our Luxury Fleet")</h2>
        <p class="section-subtitle">@(isArabic ? "اختر سيارتك المثالية من مجموعتنا المختارة" : "Choose your perfect car from our curated collection")</p>

        @if (!Model.Any())
        {
            <div class="no-cars-message">
                <i class="fas fa-car"></i>
                <p>@(isArabic ? "لا توجد سيارات متاحة حالياً" : "No cars available at the moment")</p>
            </div>
        }
        else
        {
            <div class="cars-grid">
                @foreach (var car in Model)
                {
                    <div class="car-card" data-aos="fade-up">
                        <div class="car-image">
                            @if (!string.IsNullOrEmpty(car.ImageUrl))
                            {
                                <img src="@car.ImageUrl" alt="@(isArabic? car.NameAr: car.Name)" loading="lazy">
                            }
                            else
                            {
                                <div class="image-placeholder">
                                    <i class="fas fa-car"></i>
                                </div>
                            }
                            <div class="car-badges">
                                @if (car.IsAvailable)
                                {
                                    <span class="badge available">@(isArabic ? "متاحة" : "Available")</span>
                                }
                                <span class="badge year">@car.Year</span>
                            </div>
                        </div>

                        <div class="car-details">
                            <h3 class="car-name">@(isArabic? car.NameAr: car.Name)</h3>

                            <div class="car-specs">
                                <div class="spec-item">
                                    <i class="fas fa-users"></i>
                                    <span>@car.Seats @(isArabic ? "مقاعد" : "Seats")</span>
                                </div>
                                <div class="spec-item">
                                    <i class="fas fa-gas-pump"></i>
                                    <span>@(isArabic? car.FuelTypeAr: car.FuelType)</span>
                                </div>
                                <div class="spec-item">
                                    <i class="fas fa-cog"></i>
                                    <span>@(isArabic? car.TransmissionAr: car.Transmission)</span>
                                </div>
                            </div>

                            <p class="car-description">@(isArabic? car.DescriptionAr: car.Description)</p>

                            <div class="car-footer">
                                <div class="car-price">
                                    <span class="price">@car.PricePerDay.ToString("N0")</span>
                                    <span class="currency">EGP @(isArabic ? "لليوم" : "/day")</span>
                                </div>

                                <button class="btn-rent" onclick="openInquiryModal('@(isArabic? car.NameAr: car.Name)')">
                                    <i class="fas fa-calendar-check"></i>
                                    @(isArabic ? "احجز الآن" : "Book Now")
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

