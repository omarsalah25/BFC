<!-- Inquiry Modal -->
<div id="inquiryModal" class="modal">
    <div class="modal-content">
        <span class="close" onclick="closeModal()">&times;</span>
        <h2 id="modalTitle">@(isArabic ? "طلب حجز" : "Booking Request")</h2>
        <form id="inquiryForm" onsubmit="submitInquiry(event)">
            <input type="hidden" id="carName" name="carName">
            <div class="form-group">
                <label for="name">@(isArabic ? "الاسم الكامل" : "Full Name")</label>
                <input type="text" id="name" name="name" required>
            </div>
            <div class="form-group">
                <label for="phone">@(isArabic ? "رقم الهاتف" : "Phone Number")</label>
                <input type="tel" id="phone" name="phone" required>
            </div>
            <div class="form-group">
                <label for="email">@(isArabic ? "البريد الإلكتروني" : "Email")</label>
                <input type="email" id="email" name="email" required>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label for="date">@(isArabic ? "تاريخ الاستلام" : "Pickup Date")</label>
                    <input type="date" id="date" name="date" required>
                </div>
                <div class="form-group">
                    <label for="days">@(isArabic ? "عدد الأيام" : "Number of Days")</label>
                    <input type="number" id="days" name="days" min="1" max="30" required>
                </div>
            </div>
            <div class="form-group">
                <label for="message">@(isArabic ? "ملاحظات إضافية" : "Additional Notes")</label>
                <textarea id="message" name="message" rows="3"></textarea>
            </div>
            <button type="submit" class="btn-submit">
                <i class="fas fa-paper-plane"></i>
                @(isArabic ? "إرسال الطلب" : "Submit Request")
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // Statistics counter animation
        function animateStats() {
            const stats = document.querySelectorAll('.stat-number[data-target]');
            stats.forEach(stat => {
                const target = parseInt(stat.getAttribute('data-target'));
                const increment = target / 50;
                let current = 0;

                const updateCounter = () => {
                    if (current < target) {
                        current += increment;
                        stat.textContent = Math.ceil(current);
                        requestAnimationFrame(updateCounter);
                    } else {
                        stat.textContent = target;
                    }
                };

                updateCounter();
            });
        }

        // Trigger animation when stats section is in view
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    animateStats();
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.5 });

        const statsBanner = document.querySelector('.stats-banner');
        if (statsBanner) {
            observer.observe(statsBanner);
        }

        // Modal functions
        function openInquiryModal(carName) {
            document.getElementById('carName').value = carName;
            document.getElementById('inquiryModal').style.display = 'block';
            document.body.style.overflow = 'hidden';
        }

        function closeModal() {
            document.getElementById('inquiryModal').style.display = 'none';
            document.body.style.overflow = 'auto';
        }

        function submitInquiry(event) {
            event.preventDefault();
            alert('@(isArabic ? "شكراً لتواصلك! سنتواصل معك خلال 24 ساعة." : "Thank you for your inquiry! We'll contact you within 24 hours.")');
            closeModal();
        }

        function submitContactForm(event) {
            event.preventDefault();
            alert('@(isArabic ? "شكراً لرسالتك! سنرد عليك قريباً." : "Thank you for your message! We'll reply soon.")');
            event.target.reset();
        }

        // Close modal when clicking outside
        window.onclick = function(event) {
            const modal = document.getElementById('inquiryModal');
            if (event.target == modal) {
                closeModal();
            }
        }

        // Smooth scroll for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });
    </script>
}