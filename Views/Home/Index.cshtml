@model IEnumerable<CarRentalPortfolio.Models.Car>
@{
    ViewData["Title"] = "Home";
    var isArabic = Context.Request.Cookies["Language"] == "ar";
    var heroImage = ViewBag.HeroImage as CarRentalPortfolio.Models.HeroImage;
}
<!-- Floating Admin Button (only show when not logged in) -->
@if (Context.Session.GetString("AdminId") == null)
{
    <a href="/Admin/Login" class="floating-admin-btn">
        <i class="fas fa-user-shield"></i>
        <span class="tooltip">@(isArabic ? "دخول المدير" : "Admin Login")</span>
    </a>
}
<!-- Hero Section with Dynamic Image -->
@if (heroImage != null)
{
    <div class="hero-section" style="background-image: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), url('@heroImage.ImageUrl');">
        <div class="hero-content">
            <span class="hero-welcome">@(isArabic ? "مرحباً بكم في" : "Welcome to")</span>
            <h1 class="hero-title">CARS ON HANDS</h1>
            <p class="hero-subtitle">@(isArabic? heroImage.SubtitleAr: heroImage.Subtitle)</p>
            <div class="hero-features">
                <div class="hero-feature">
                    <i class="fas fa-check-circle"></i>
                    <span>@(isArabic ? "لا أوراق معقدة" : "No Paperwork")</span>
                </div>
                <div class="hero-feature">
                    <i class="fas fa-check-circle"></i>
                    <span>@(isArabic ? "أسعار تنافسية" : "Competitive Prices")</span>
                </div>
                <div class="hero-feature">
                    <i class="fas fa-check-circle"></i>
                    <span>@(isArabic ? "دعم 24/7" : "24/7 Support")</span>
                </div>
            </div>
            <div class="hero-buttons">
                <a href="#cars" class="btn-primary">
                    <i class="fas fa-car"></i>
                    @(isArabic ? "استعرض السيارات" : "Browse Cars")
                </a>
                <a href="/Home/About" class="btn-secondary">
                    <i class="fas fa-info-circle"></i>
                    @(isArabic ? "تعرف علينا" : "About Us")
                </a>
            </div>
        </div>
    </div>
}

