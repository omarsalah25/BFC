</section>

<!-- Statistics Banner -->
<section class="stats-banner">
    <div class="container">
        <div class="stats-grid">
            <div class="stat-item">
                <i class="fas fa-car-side"></i>
                <span class="stat-number" data-target="@Model.Count()">0</span>
                <span class="stat-label">@(isArabic ? "سيارة متاحة" : "Available Cars")</span>
            </div>
            <div class="stat-item">
                <i class="fas fa-users"></i>
                <span class="stat-number" data-target="5000">0</span>
                <span class="stat-label">@(isArabic ? "عميل سعيد" : "Happy Clients")</span>
            </div>
            <div class="stat-item">
                <i class="fas fa-calendar-check"></i>
                <span class="stat-number" data-target="15000">0</span>
                <span class="stat-label">@(isArabic ? "رحلة ناجحة" : "Successful Trips")</span>
            </div>
            <div class="stat-item">
                <i class="fas fa-map-marker-alt"></i>
                <span class="stat-number" data-target="27">0</span>
                <span class="stat-label">@(isArabic ? "محافظة" : "Governorates")</span>
            </div>
        </div>
    </div>
</section>

<!-- Cars Section -->
<section id="cars" class="cars-section">
    <div class="container">
        <h2 class="section-title">@(isArabic? ViewBag.Settings.CarsTitleAr : ViewBag.Settings.CarsTitleEn)</h2>
        <p class="section-subtitle">@(isArabic? ViewBag.Settings.CarsSubtitleAr : ViewBag.Settings.CarsSubtitleEn)</p>

        @if (!Model.Any())
        {
            <div class="no-cars-message">
                <i class="fas fa-car"></i>
                <p>@(isArabic ? "لا توجد سيارات متاحة حالياً" : "No cars available at the moment")</p>
            </div>
        }
        else
        {
            <div class="cars-grid">
                @foreach (var car in Model)
                {
                    var carName = isArabic ? car.NameAr : car.Name;
                    var message = isArabic ?
                    $"مرحباً، أود الاستعلام عن سيارة {carName} للتأجير" :
                    $"Hello, I'm interested in renting the {carName}";
                    var whatsappUrl = $"https://wa.me/{ViewBag.Settings.WhatsAppNumber}?text={Uri.EscapeDataString(message)}";

                    <div class="car-card" onclick="window.open('@whatsappUrl', '_blank')">
                        <div class="car-image">
                            @if (!string.IsNullOrEmpty(car.ImageUrl))
                            {
                                <img src="@car.ImageUrl" alt="@carName" loading="lazy">
                            }
                            else
                            {
                                <div class="image-placeholder">
                                    <i class="fas fa-car"></i>
                                </div>
                            }
                            <div class="car-badges">
                                @if (car.IsAvailable)
                                {
                                    <span class="badge available">@(isArabic ? "متاحة الآن" : "Available Now")</span>
                                }
                                <span class="badge year">@car.Year</span>
                            </div>
                        </div>

                        <div class="car-details">
                            <h3 class="car-name">@carName</h3>

                            <div class="car-specs">
                                <div class="spec-item">
                                    <i class="fas fa-users"></i>
                                    <span>@car.Seats @(isArabic ? "مقاعد" : "Seats")</span>
                                </div>
                                <div class="spec-item">
                                    <i class="fas fa-gas-pump"></i>
                                    <span>@(isArabic? car.FuelTypeAr: car.FuelType)</span>
                                </div>
                                <div class="spec-item">
                                    <i class="fas fa-cog"></i>
                                    <span>@(isArabic? car.TransmissionAr: car.Transmission)</span>
                                </div>
                            </div>

                            <p class="car-description">@(isArabic? car.DescriptionAr: car.Description)</p>

                            <div class="car-footer">
                                <div class="car-price">
                                    @if (car.PricePerDay > 0)
                                    {
                                        <div class="car-price">
                                            <span class="price">@car.PricePerDay.ToString("N0")</span>
                                            <span class="currency">EGP @(isArabic ? "لليوم" : "/day")</span>
                                        </div>
                                    }
                                            <span class="currency">EGP @(isArabic ? "لليوم" : "/day")</span>
                                </div>

                                <button class="btn-rent" onclick="event.stopPropagation(); window.open('@whatsappUrl', '_blank')">
                                    <i class="fab fa-whatsapp"></i>
                                    @(isArabic ? "احجز عبر واتساب" : "Book via WhatsApp")
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

