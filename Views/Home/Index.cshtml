                <div class="feature-icon">
                    <i class="fas fa-clock"></i>
                </div>
                <h3>@(isArabic ? "مرونة كاملة" : "Complete Flexibility")</h3>
                <p>@(isArabic ? "استلم وأعد السيارة في الوقت والمكان الذي يناسبك" : "Pick up and return at your convenience")</p>
