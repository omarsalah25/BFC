                            <p>info@h-car.com</p>
                        </div>
                    </div>

                    <div class="contact-item">
                        <i class="fas fa-map-marker-alt"></i>
                        <div>
                            <h4>@(isArabic ? "خدماتنا" : "Our Services")</h4>
