@model IEnumerable<CarRentalPortfolio.Models.Car>
@{
    ViewData["Title"] = "H-Car - Premium Car Rentals in Egypt";
    var isArabic = Context.Request.Cookies["Language"] == "ar";
    var heroImage = ViewBag.HeroImage as CarRentalPortfolio.Models.HeroImage;
}
<style>
    .philosophy-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        align-items: center;
    }

    @@media (max-width: 768px) {
        .philosophy-grid {
            grid-template-columns: 1fr;
        }
    }

    .hero-section {
        min-height: 85vh; /* Makes the hero image take up 85% of the screen height */
        background-size: cover;
        background-position: center;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .philosophy-message-box {
        background: var(--gray-100, #f8f9fa);
        padding: 2rem;
        border-radius: 15px;
        margin: 2rem 0;
        border-left: 5px solid var(--accent);
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

    .philosophy-main {
        font-size: 1.15rem;
        line-height: 1.8;
        color: var(--text-dark);
        margin: 0;
        display: block; /* This prevents the vertical squishing */
        width: 100%;
        text-align: justify;
    }

    .quote-icon {
        font-size: 2rem;
        color: var(--accent);
        margin-bottom: 1rem;
        opacity: 0.5;
    }
</style>
<!-- Floating WhatsApp Button -->
<a href="https://wa.me/@ViewBag.Settings.WhatsAppNumber" class="whatsapp-float" target="_blank">
    <i class="fab fa-whatsapp"></i>
    <span class="tooltip">@(isArabic ? "تواصل معنا عبر واتساب" : "Chat with us on WhatsApp")</span>
</a>

<!-- Floating Admin Button (only show when not logged in) -->
@if (Context.Session.GetString("AdminId") == null)
{
    <a href="/Admin/Login" class="floating-admin-btn">
        <i class="fas fa-user-shield"></i>
        <span class="tooltip">@(isArabic ? "دخول المدير" : "Admin Login")</span>
    </a>
}

<!-- Hero Section with Dynamic Image -->
@if (heroImage != null)
{
    <div class="hero-section" style="background-image: linear-gradient(rgba(0, 0, 0, 0.3), rgba(0, 0, 0, 0.4)), url('@heroImage.ImageUrl');">
        <div class="hero-content">
            <span class="hero-welcome">@(isArabic ? "اكتشف مصر بأناقة" : "Explore Egypt in Style")</span>
            <h1 class="hero-title">H-CAR</h1>
            <p class="hero-subtitle">
                @(isArabic ? "سيارات دفع رباعي وسيدان فاخرة مع خدمة التوصيل والاستلام في جميع أنحاء البلاد"
                            : "Premium SUVs and Sedans with pick-up & drop-off across the country")
        </p>
        <div class="hero-features">
            <div class="hero-feature">
                <i class="fas fa-check-circle"></i>
                <span>@(isArabic ? "توصيل مجاني" : "Free Delivery")</span>
            </div>
            <div class="hero-feature">
                <i class="fas fa-check-circle"></i>
                <span>@(isArabic ? "أسعار تنافسية" : "Best Prices")</span>
            </div>
            <div class="hero-feature">
                <i class="fas fa-check-circle"></i>
                <span>@(isArabic ? "دعم 24/7" : "24/7 Support")</span>
            </div>
        </div>
        <div class="hero-buttons">
            <a href="#cars" class="btn-primary">
                <i class="fas fa-car"></i>
                @(isArabic ? "اختر سيارتك الآن" : "Choose Your Car Now")
            </a>
            <a href="/Home/About" class="btn-secondary">
                <i class="fas fa-info-circle"></i>
                @(isArabic ? "تعرف علينا" : "About Us")
            </a>
        </div>
    </div>
</div>
}

<!-- Company Philosophy Section -->
<section class="philosophy-section">
    <div class="container">
        <div class="philosophy-grid">
            <div class="philosophy-content">
                <!-- EXACTLY LIKE THIS -->
                <h2 class="section-title-left">@(isArabic ? "لماذا H-CAR؟" : "Why H-CAR?")</h2>
                <div class="philosophy-message-box">
                    <i class="fas fa-quote-right quote-icon"></i>
                    <p class="philosophy-main">
                        @(isArabic ? "في H-CAR، نقدم لك تجربة قيادة استثنائية مع أسطول من السيارات الفاخرة التي تناسب جميع المناسبات. سواء كنت تخطط لرحلة عمل أو عطلة عائلية، نحن هنا لجعل رحلتك لا تُنسى."
                                                : "At H-CAR, we offer you an exceptional driving experience with a fleet of luxury cars suitable for all occasions. Whether you're planning a business trip or a family vacation, we're here to make your journey unforgettable.")
                    </p>
                </div>
                <div class="philosophy-stats">
                    <div class="stat-item">
                        <span class="stat-number">10+</span>
                        <span class="stat-label">@(isArabic ? "سنوات خبرة" : "Years Experience")</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-number">5000+</span>
                        <span class="stat-label">@(isArabic ? "عميل سعيد" : "Happy Clients")</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-number">100+</span>
                        <span class="stat-label">@(isArabic ? "سيارة فاخرة" : "Luxury Cars")</span>
                    </div>
                </div>
            </div>
            <div class="philosophy-image">
                <img src="@(ViewBag.Settings.PhilosophyImageUrl ?? "https://images.unsplash.com/photo-1533473359331-0135ef1b58bf?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80")" alt="Luxury Car Rental Egypt" class="philosophy-img">
                <div class="experience-badge">
                    <i class="fas fa-star"></i>
                    <span>@(isArabic ? "خدمة متميزة" : "Premium Service")</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features Section -->
