                    <i class="fas fa-wallet"></i>
                </div>
                <h3>@(isArabic ? "أسعار تنافسية" : "Best Prices")</h3>
                <p>@(isArabic ? "أفضل الأسعار مع أعلى مستوى من الخدمة" : "Best prices with highest service quality")</p>
            </div>

