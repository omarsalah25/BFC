                <form id="contactForm" onsubmit="submitContactForm(event)">
                    <div class="form-group">
                        <input type="text" placeholder="@(isArabic ? "الاسم" : "Name")" required>
                    </div>
                    <div class="form-group">
                        <input type="email" placeholder="@(isArabic ? "البريد الإلكتروني" : "Email")" required>
