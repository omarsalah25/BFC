<!DOCTYPE html>
@{
    var currentLang = Context.Request.Cookies["Language"] ?? "en";
    var isArabic = currentLang == "ar";
    var settings = Context.Items["SiteSettings"] as CarRentalPortfolio.Models.SiteSettings;
}
<html lang="@currentLang" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @(settings?.SiteName ?? "H-CAR")</title>

    @await Component.InvokeAsync("SiteSettings")

    @if (settings != null)
    {
        <link rel="icon" type="image/png" href="@settings.FaviconUrl">
        <link rel="apple-touch-icon" href="@settings.LogoUrl">

        <!-- ADD THIS STYLE BLOCK TO APPLY DYNAMIC COLORS -->
        <style>
            :root {
                --primary: @settings.PrimaryColor !important;
                --primary-dark: @settings.PrimaryDarkColor !important;
                --primary-light: @settings.PrimaryLightColor !important;
                --accent: @settings.AccentColor !important;
                --accent-dark: @settings.AccentDarkColor !important;
                --background: @settings.BackgroundColor !important;
                --surface: @settings.SurfaceColor !important;
                --text-dark: @settings.TextDarkColor !important;
                --text-light: @settings.TextLightColor !important;
            }
        </style>
    }
    else
    {
        <link rel="icon" type="image/png" href="/images/icon.png">
        <link rel="apple-touch-icon" href="/images/icon.png">
    }

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="wrapper">
        <nav class="navbar">
            <div class="nav-container">
                <div class="nav-logo">
                    <a href="/">
                        @if (settings != null && !string.IsNullOrEmpty(settings.LogoUrl))
                        {
                            <img src="@settings.LogoUrl" alt="@(isArabic? settings.SiteNameAr: settings.SiteName)" style="height: 80px; max-width: 250px; object-fit: contain; margin: 5px 0;">
                        }
                        else
                        {
                            <span class="logo-text">@(isArabic? settings?.SiteNameAr ?? "H-CAR" : settings?.SiteName ?? "H-CAR")</span>
                            <span class="logo-sub">@(isArabic? settings?.FooterTextAr ?? "تأجير سيارات فاخرة" : settings?.FooterTextEn ?? "Luxury Car Rental")</span>
                        }
                    </a>
                </div>

                <div class="nav-menu">
                    <a href="/" class="nav-link">@(isArabic ? "الرئيسية" : "Home")</a>
                    <a href="/Home/About" class="nav-link">@(isArabic ? "عن الشركة" : "About")</a>
                    @if (Context.Session.GetString("AdminId") != null)
                    {
                        <a href="/Admin/Dashboard" class="nav-link">@(isArabic ? "لوحة التحكم" : "Dashboard")</a>
                        <a href="/Admin/Cars" class="nav-link">@(isArabic ? "السيارات" : "Cars")</a>
                        <a href="/SiteSettings" class="nav-link">@(isArabic ? "الإعدادات" : "Settings")</a>
                        <a href="/Admin/Logout" class="nav-link">@(isArabic ? "تسجيل خروج" : "Logout")</a>
                    }
                </div>

                <div class="nav-actions">
                    <div class="language-switch">
                        <a href="/Home/ChangeLanguage?lang=en" class="lang-link @(currentLang == "en" ? "active" : "")">EN</a>
                        <span class="lang-separator">|</span>
                        <a href="/Home/ChangeLanguage?lang=ar" class="lang-link @(currentLang == "ar" ? "active" : "")">AR</a>
                    </div>

              @*       @if (Context.Session.GetString("AdminId") == null)
                    {
                        <a href="/Admin/Login" class="admin-login-btn">
                            <i class="fas fa-user-shield"></i>
                            <span>@(isArabic ? "دخول المدير" : "Admin Login")</span>
                        </a>
                    }
                    *@
                </div>
            </div>
        </nav>
        <main role="main">
            @RenderBody()
        </main>

        <footer class="footer">
            <div class="footer-container">
                <div class="footer-content">
                    <div class="footer-brand">
                        <h3 style="color: var(--accent);">@(isArabic? settings?.SiteNameAr ?? "H-CAR" : settings?.SiteName ?? "H-CAR")</h3>
                        <p>@(isArabic? settings?.FooterTextAr ?? "تأجير سيارات فاخرة في مصر" : settings?.FooterTextEn ?? "Luxury Car Rental in Egypt")</p>
                    </div>
                    <div class="footer-philosophy">
                        <p class="philosophy-text">
                            <i class="fas fa-heart" style="color: var(--accent);"></i>
                            @(isArabic? settings?.PhilosophyAr ?? "راحتك هي أولويتنا القصوى" : settings?.PhilosophyEn ?? "Your comfort is our top priority")
                        </p>
                    </div>
                </div>
                <div class="footer-bottom">
                    <p>&copy; @DateTime.Now.Year - @(isArabic? settings?.SiteNameAr ?? "H-CAR" : settings?.SiteName ?? "H-CAR"). @(isArabic ? "جميع الحقوق محفوظة" : "All rights reserved")</p>
                </div>
            </div>
        </footer>
    </div>

    @if (settings != null)
    {
        <a href="https://wa.me/@settings.WhatsAppNumber" class="whatsapp-float" target="_blank">
            <i class="fab fa-whatsapp"></i>
            <span class="tooltip">@(isArabic ? "تواصل معنا عبر واتساب" : "Chat with us on WhatsApp")</span>
        </a>
    }

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>